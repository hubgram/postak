# Telegram bot token from @BotFather (https://t.me/BotFather)
# Format: <bot_id>:<auth_string>
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrStUVwxyz

# Numeric id of the channel the bot accepts /new from (e.g. -1001234567890)
TARGET_CHANNEL_ID=-1001234567890

# OpenAI-compatible LLM used to answer comments.
# Endpoint base URL (leave empty for the default OpenAI API).
LLM_ENDPOINT=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-...

# Conversation store: "sqlite" (persistent, default) or "memory".
STORE=sqlite
SQLITE_PATH=posttalk.db
# Max recent messages kept as context; the system prompt is always kept.
HISTORY_WINDOW=20

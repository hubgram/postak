# Telegram bot token from @BotFather (https://t.me/BotFather)
# Format: <bot_id>:<auth_string>
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrStUVwxyz

# Numeric id(s) of the channel(s) the bot accepts /new from,
# comma-separated for multiple (e.g. -1001234567890,-1009876543210).
# Optional: leave empty and a Postak admin can link channels later with
# /postak add, or just by sending /new in a new channel's discussion group.
TARGET_CHANNEL_ID=-1001234567890

# Comma-separated Telegram user ids that may manage Postak access rules.
# Required if TARGET_CHANNEL_ID is empty - it's the only way to add a channel.
POSTAK_ADMINS=123456789

# OpenAI-compatible LLM used to answer comments.
# Endpoint base URL (leave empty for the default OpenAI API).
LLM_ENDPOINT=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-...

# Conversation store, as a database URL:
#   :memory:                         -> ephemeral in-memory (lost on restart)
#   sqlite+aiosqlite:///postak.db  -> persistent SQLite file
DATABASE_URL=sqlite+aiosqlite:///postak.db
# Max recent messages kept as context; the system prompt is always kept.
HISTORY_WINDOW=50
